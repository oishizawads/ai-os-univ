{
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"C:/workspace/ai-os/hooks/lib/rotate_daily_report.py\""
          },
          {
            "type": "command",
            "command": "python \"C:/workspace/ai-os/hooks/lib/session_notes_sync.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"C:/workspace/ai-os/hooks/lib/guard_dangerous_commands.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python \"C:/workspace/ai-os/hooks/lib/suggest_claude_md.py\""
          },
          {
            "type": "command",
            "command": "python \"C:/workspace/ai-os/hooks/lib/auto_ledger.py\""
          }
        ]
      }
    ]
  }
}
